/* ════════════════════════════════════════
   CSV / XLSX IMPORT
════════════════════════════════════════ */
function dragOver(e){ e.preventDefault(); document.getElementById('drop-zone').classList.add('drag'); }
function dragLeave(e){ document.getElementById('drop-zone').classList.remove('drag'); }
function dropFile(e){
  e.preventDefault(); dragLeave(e);
  const f=e.dataTransfer.files[0];
  if(f) handleFileImport(f);
}
function handleFileImport(file){
  if(!file) return;
  const ext=file.name.split('.').pop().toLowerCase();
  if(!['csv','xlsx','xls'].includes(ext)){ toast('⚠️ รองรับเฉพาะ .csv และ .xlsx'); return; }
  const reader=new FileReader();
  reader.onload=function(e){
    let rows=[];
    if(ext==='csv'){
      rows=parseCSV(e.target.result);
    } else {
      const wb=XLSX.read(e.target.result,{type:'binary'});
      const ws=wb.Sheets[wb.SheetNames[0]];
      rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
    }
    if(!rows.length){ toast('⚠️ ไม่พบข้อมูลในไฟล์'); return; }
    showImportPreview(rows, file.name);
  };
  if(ext==='csv') reader.readAsText(file,'UTF-8');
  else reader.readAsBinaryString(file);
}
function parseCSV(text){
  return text.split('\n').filter(l=>l.trim()).map(l=>
    l.split(',').map(c=>c.trim().replace(/^"|"$/g,''))
  );
}
function showImportPreview(rows, fname){
  // auto-detect header row (first row)
  const header=rows[0];
  const dataRows=rows.slice(1).filter(r=>r.some(c=>String(c).trim()));
  importBuffer=dataRows;

  document.getElementById('prev-title').textContent=`ตัวอย่างข้อมูลจาก "${fname}" (${Math.min(5,dataRows.length)} / ${dataRows.length} แถว)`;
  document.getElementById('prev-count').textContent=dataRows.length+' นาย';

  // Build header
  document.getElementById('prev-head').innerHTML=header.map(h=>`<th>${esc(String(h))}</th>`).join('');
  // Build preview body (first 5 rows)
  document.getElementById('prev-body').innerHTML=dataRows.slice(0,5).map(r=>
    `<tr>${r.map(c=>`<td>${esc(String(c))}</td>`).join('')}</tr>`
  ).join('');

  document.getElementById('import-preview').classList.remove('hidden');
}
function confirmImport(){
  // Try to map columns: col 0=name, col 1=no, col 2=group, col 3=status
  let added=0;
  importBuffer.forEach(row=>{
    const name=String(row[0]||'').trim();
    if(!name) return;
    const rawStatus=String(row[3]||'ok').toLowerCase();
    let status='ok';
    if(rawStatus.includes('รอ')||rawStatus.includes('pending')) status='pending';
    else if(rawStatus.includes('ขาด')||rawStatus.includes('err')) status='err';
    students.push({
      id:nextStId++, name,
      no:String(row[1]||'').trim(),
      group:String(row[2]||'กลุ่มที่ 1').trim(),
      status
    });
    added++;
  });
  importBuffer=[];
  document.getElementById('import-preview').classList.add('hidden');
  document.getElementById('file-import').value='';
  renderStudents(); toast(`✅ นำเข้านักเรียน ${added} คนเรียบร้อยแล้ว`);
}
function cancelImport(){
  importBuffer=[];
  document.getElementById('import-preview').classList.add('hidden');
  document.getElementById('file-import').value='';
  toast('ℹ️ ยกเลิกการนำเข้าแล้ว');
}

/* ── Download Template ── */
function downloadTemplate(type){
  const header=['ยศ-ชื่อ-สกุล','เลขประจำตัว','กลุ่ม','สถานะ'];
  const sample=[
    ['จ.อ.สมชาย ใจดี','6900001','กลุ่มที่ 1','ok'],
    ['จ.อ.สมศักดิ์ รักไทย','6900002','กลุ่มที่ 1','ok'],
    ['จ.อ.สมหมาย พรหมดี','6900003','กลุ่มที่ 2','pending'],
  ];
  if(type==='csv'){
    const csv=[header,...sample].map(r=>r.join(',')).join('\n');
    const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
    dlBlob(blob,'student_template.csv');
  } else {
    const wb=XLSX.utils.book_new();
    const ws=XLSX.utils.aoa_to_sheet([header,...sample]);
    XLSX.utils.book_append_sheet(wb,ws,'นักเรียน');
    XLSX.writeFile(wb,'student_template.xlsx');
  }
  toast('⬇ ดาวน์โหลด Template แล้ว');
}
function exportStudentsCSV(){
  if(!students.length){ toast('⚠️ ยังไม่มีข้อมูลนักเรียน'); return; }
  const rows=[['ยศ-ชื่อ-สกุล','เลขประจำตัว','กลุ่ม','สถานะ'],...students.map(s=>[s.name,s.no||'',s.group||'',s.status||'ok'])];
  const csv=rows.map(r=>r.join(',')).join('\n');
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  dlBlob(blob,'students_export.csv');
  toast('📤 Export CSV เรียบร้อยแล้ว');
}
function dlBlob(blob, fname){
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download=fname; a.click();
  URL.revokeObjectURL(a.href);
}

/* ════════════════════════════════════════
   ANNOUNCEMENTS
════════════════════════════════════════ */
const annIcon={urgent:'🚨',info:'ℹ️',success:'✅',''  :'🏫'};
function renderAnnounces(){
  const list=announces;
  const isAdmin=currentUser&&currentUser.role==='admin';
  document.getElementById('ann-list').innerHTML=list.map(a=>`
    <div class="ann-item ${a.level||''}">
      <div class="ann-icon">${annIcon[a.level||'']||'📌'}</div>
      <div style="flex:1">
        <h4>${esc(a.title)}</h4>
        <p>${esc(a.body)}</p>
        <div class="ann-date">📅 ${formatDate(a.date)}</div>
      </div>
      ${isAdmin?`<button class="btn btn-err btn-xs" onclick="delAnnounce(${a.id})" style="flex-shrink:0">🗑</button>`:''}
    </div>`).join('');
  updateStats();
}
function renderDashAnnounces(){
  document.getElementById('dash-announce').innerHTML=
    announces.slice(0,3).map(a=>`
    <div class="ann-item ${a.level||''}">
      <div class="ann-icon">${annIcon[a.level||'']||'📌'}</div>
      <div>
        <h4>${esc(a.title)}</h4>
        <p>${esc(a.body)}</p>
        <div class="ann-date">📅 ${formatDate(a.date)}</div>
      </div>
    </div>`).join('');
}
function addAnnounce(){
  const title=document.getElementById('ann-title').value.trim();
  if(!title){ toast('⚠️ กรุณากรอกหัวข้อประกาศ'); return; }
  announces.unshift({
    id:nextAnnId++, title,
    body:document.getElementById('ann-body').value.trim(),
    level:document.getElementById('ann-level').value,
    date:document.getElementById('ann-date').value||new Date().toISOString().slice(0,10)
  });
  ['ann-title','ann-body'].forEach(i=>document.getElementById(i).value='');
  renderAnnounces(); toast('📣 เพิ่มประกาศเรียบร้อยแล้ว');
}
function delAnnounce(id){
  if(!confirm('ลบประกาศนี้?')) return;
  announces=announces.filter(a=>a.id!==id);
  renderAnnounces(); toast('🗑 ลบประกาศแล้ว');
}
function formatDate(d){
  if(!d) return '—';
  try{
    const dt=new Date(d);
    return dt.toLocaleDateString('th-TH',{year:'numeric',month:'long',day:'numeric'});
  }catch{ return d; }
}

